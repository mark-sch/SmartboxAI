# Target URL to forward requests to (e.g. Kimi Code API)
PROXY_TARGET_URL=https://api.kimi.com/coding/v1

# Auth token that clients must present to the proxy
PROXY_AUTH_TOKEN=your-proxy-auth-token

# Token used when forwarding to the target.
# If PROXY_REFRESH_TOKEN is set, the proxy will auto-refresh this token.
# Otherwise, you must keep this token up to date manually.
PROXY_TARGET_TOKEN=your-target-api-key

# Optional: refresh token for automatic token refresh.
# If set, the proxy will refresh PROXY_TARGET_TOKEN automatically before expiry.
# PROXY_REFRESH_TOKEN=your-refresh-token

# Port the proxy server listens on
PROXY_PORT=3000

# Log level: verbose | info | error (default: info)
PROXY_LOG_LEVEL=info

# Optional: OAuth host for token refresh (default: https://auth.kimi.com)
# OAUTH_HOST=https://auth.kimi.com

# Optional: override the x-msh-device-id header for all sessions
# (comma-separated list for round-robin rotation)
# PROXY_DEVICE_ID=your-device-id

# Optional: override the User-Agent header forwarded to the target
# PROXY_USER_AGENT=KimiCLI/1.32.0
